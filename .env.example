# AI
VITE_GEMINI_API_KEY=

# Supabase — frontend (safe to expose; the anon key is public, RLS protects data)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# App URL (used for the badge metadata URI)
VITE_APP_URL=

# ── Server-only (Vercel Functions) — NEVER prefix with VITE_, never commit real values ──
# Supabase service role (bypasses RLS) — used by /api/mint-badge to verify the JWT + write badge rows
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Solana devnet — soulbound badge minting (/api/mint-badge)
SOLANA_RPC_URL=
# base58 secret key of the mint-authority / fee-payer wallet (pre-fund it with devnet SOL)
MINT_AUTHORITY_SECRET_KEY=
